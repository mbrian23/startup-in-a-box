# Host port overrides for `docker compose` (demo mode).
# Copy to `.env` at repo root and change any that conflict with other
# services on your machine. The compose file reads these; containers
# always listen on the canonical internal ports (3000/8000/8888).
#
# Changing HOST_PORT_FACTORY requires a frontend rebuild, because
# NEXT_PUBLIC_FACTORY_URL is baked in at build time:
#
#   docker compose build frontend

HOST_PORT_WEB=3000
HOST_PORT_ORCH=8000
HOST_PORT_FACTORY=8888
