# Orchestrator environment variables
# Copy to .env and fill in values.

# FastAPI port
PORT=8000

# Allowed CORS origins (comma-separated). Frontend dev server default.
CORS_ORIGINS=http://localhost:3000

# ── Model transport ─────────────────────────────────────────────────
# Default: OpenRouter (works with any provider it supports).
# Set OPENROUTER_API_KEY and leave the model names as-is.
OPENROUTER_API_KEY=
ORCHESTRATOR_MODEL=openrouter/google/gemini-2.5-flash
CEO_MODEL=openrouter/google/gemini-2.5-flash
CTO_MODEL=openrouter/google/gemini-2.5-pro

# ── Native Gemini (alternative) ────────────────────────────────────
# Uncomment these and comment out the OpenRouter block above to use
# google-genai directly. Burns the free-tier 250 req/day quota on Pro.
# GOOGLE_API_KEY=
# ORCHESTRATOR_MODEL=gemini-3-flash-preview
# CEO_MODEL=gemini-3-flash-preview
# CTO_MODEL=gemini-3.1-pro-preview

# ── Local models via LM Studio (alternative) ───────────────────────
# Uncomment these for fully local inference. No API key needed.
# ORCHESTRATOR_MODEL=openai/qwen/qwen3.5-9b
# CEO_MODEL=openai/qwen/qwen3.5-9b
# CTO_MODEL=openai/qwen/qwen3.5-9b
# API_BASE_URL=http://127.0.0.1:1234
# OPENAI_API_BASE=http://127.0.0.1:1234/v1
# OPENAI_API_KEY=dummy-key

# URL where the Software Factory's AG-UI endpoint is served.
FACTORY_URL=http://localhost:8888/factory

# Structured logging toggle. Default human-readable.
LOG_JSONL=0
