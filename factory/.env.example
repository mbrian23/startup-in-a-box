# Factory environment variables — copy to .env and fill in values.

PORT=8888
CORS_ORIGINS=http://localhost:3000

# ── Claude API (default: OpenRouter — recommended) ────────────────
# One OpenRouter key covers everything. Set it here and leave
# ANTHROPIC_BASE_URL pointing at OpenRouter.
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://openrouter.ai/api/v1

# Top-level runner model. Subagents pin their own tier in subagents.py
# (architect=opus, implementer/build_reviewer=sonnet, tester/devops=haiku)
# so rate-limit pressure spreads across all three buckets.
#
# Model names use the OpenRouter format (anthropic/<model>).
# If you switch to the native Anthropic API (sk-ant-... key, blank
# ANTHROPIC_BASE_URL), drop the "anthropic/" prefix:
#   anthropic/claude-opus-4.7   → claude-opus-4-7-20250219
#   anthropic/claude-haiku-4.5  → claude-haiku-4-5-20251001
FACTORY_MODEL=anthropic/claude-opus-4.7

# Per-run workspace root (relative paths resolve to factory/workspace/).
WORKSPACE_ROOT=workspace

# ── Deploy credentials (optional) ──────────────────────────────────
# Without these the factory builds locally — output in workspace/.
# With them, the devops subagent pushes to GitHub and deploys to Vercel.
#   https://github.com/settings/tokens (scopes: repo, delete_repo)
#   https://vercel.com/account/tokens
GITHUB_TOKEN=
VERCEL_TOKEN=

# ── Optional: Vercel AI Gateway ─────────────────────────────────────
# When set, the devops subagent pushes this key into each generated
# Vercel project's env, activating the real LLM path. Without it,
# generated sites still work (mock responses).
# Get a key at: https://vercel.com/dashboard/ai-gateway → API Keys.
AI_GATEWAY_API_KEY=
