# Keep the build context small and avoid baking secrets/build artifacts.

.git
.gitignore
.DS_Store

# Secrets
**/.env
**/.env.local

# Python
**/__pycache__
**/*.pyc
**/.pytest_cache
**/.ruff_cache
**/.venv

# Node / Next.js
**/node_modules
**/.next
**/dist
**/.vite

# Forensic logs (generated per-session)
logs

# Factory per-run workspace output
factory/workspace
factory/.claude/*.local.*

# Editor / OS noise
.idea
.vscode
*.swp

# Local Docker artifacts
Dockerfile.*.local
docker-compose.override.yml
